{
    "containerDefinitions": [
        {
            "name": "erielab-webservice-container",
            "image": "471112823728.dkr.ecr.us-west-2.amazonaws.com/erielab-webservice:latest",
            "cpu": 1024,
            "memory": 1024,
            "portMappings": [
                {
                    "containerPort": 8001,
                    "hostPort": 8001,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "ERIELAB_ENV",
                    "value": "prod"
                },
                {
                    "name": "AWS_REGION",
                    "value": "us-west-2"
                }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "erielab-container-volume",
                    "containerPath": "/app/staticfiles",
                    "readOnly": false
                }
            ],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "erielab-webservice-loggroup",
                    "awslogs-region": "us-west-2",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "systemControls": []
        }
    ],
    "family": "erielab-webservice-taskdefinition-3",
    "taskRoleArn": "arn:aws:iam::471112823728:role/erielab-container-role",
    "networkMode": "bridge",
    "volumes": [
        {
            "name": "erielab-container-volume",
            "host": {
                "sourcePath": "/opt/erielab-container-volume"
            }
        }
    ],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "EC2"
    ],
    "cpu": "1792",
    "memory": "3584",
    "tags": []
}