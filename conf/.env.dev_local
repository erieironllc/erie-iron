BASE_URL="http://localhost:8000"

AWS_ACCOUNT_ID=000000000000
AWS_DEFAULT_REGION_NAME="us-west-2"

STATIC_COMPILED_DIR="erieiron_ui/static/compiled"
CSRF_TRUSTED_ORIGINS="http://localhost:8000,http://127.0.0.1:8000"

START_MESSAGE_QUEUE_PROCESSOR=True
MESSAGE_QUEUE_ENV="local"

ERIEIRON_RUNTIME_PROFILE="local"
ERIEIRON_LOCAL_SECRETS_FILE="conf/local_secrets.json"
LOCAL_DB_NAME="erieiron_local"
LOCAL_AUTH_ENABLED=True
LOCAL_AUTH_EMAIL="local-admin@erieiron.local"
LOCAL_AUTH_PASSWORD="change-me-local-password"
LOCAL_AUTH_NAME="Local Admin"
DISABLE_EMAIL_SEND=True
ALLOW_MPS_DEVICE=True
S3_CACHE_DIR="/tmp/s3cache"
S3_CACHE_MAX_DISK_USAGE=50

DEBUG=True
