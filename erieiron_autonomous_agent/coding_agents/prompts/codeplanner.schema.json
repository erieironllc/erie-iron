{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/codeplanner-base-output.schema.json",
  "title": "CodePlannerBaseOutput",
  "description": "Structured output of the Erie Iron code planner agent",
  "type": "object",
  "oneOf": [
    {
      "title": "Planned Code Change",
      "required": ["execute_module", "test_module", "code_files"],
      "properties": {
        "execute_module": {
          "type": "string",
          "description": "Relative path to the module containing the execute() or train() method"
        },
        "test_module": {
          "type": "string",
          "description": "Relative path to the module containing the test() method"
        },
        "code_files": {
          "type": "array",
          "description": "List of file-level deterministic planning instructions",
          "items": {
            "type": "object",
            "required": ["code_file_path", "instructions"],
            "properties": {
              "code_file_path": {
                "type": "string",
                "description": "Relative file path to be created or modified"
              },
              "instructions": {
                "type": "array",
                "description": "Ordered steps for how the code_writer should modify the file",
                "items": {
                  "type": "object",
                  "required": ["step_number", "action", "details"],
                  "properties": {
                    "step_number": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Step number in execution order"
                    },
                    "action": {
                      "type": "string",
                      "description": "Short summary of the operation, e.g., 'create function `train`'"
                    },
                    "details": {
                      "type": "string",
                      "description": "Detailed, testable description of the change"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Blocked Task",
      "required": ["blocked"],
      "properties": {
        "blocked": {
          "type": "object",
          "required": ["category", "reason"],
          "properties": {
            "category": {
              "type": "string",
              "enum": ["task_def", "infra", "missing_context", "permissions", "unexpected_error"],
              "description": "Reason category for blocking"
            },
            "reason": {
              "type": "string",
              "description": "Explanation of why planning is blocked"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}