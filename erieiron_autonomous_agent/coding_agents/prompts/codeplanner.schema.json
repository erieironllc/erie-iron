{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/codeplanner-base-output.schema.json",
  "title": "CodePlannerBaseOutput",
  "description": "Structured output of the Erie Iron code planner agent",
  "type": "object",
  "oneOf": [
    {
      "title": "Planned Code Change",
      "required": ["code_files"],
      "properties": {
        "lessons_applied": {
          "type": "array",
          "description": "List of past lesson patterns that influenced this plan",
          "items": {
            "type": "string"
          }
        },
        "dsl_plan": {
          "type": "array",
          "description": "Structured plan using DSL format for multi-file coordination",
          "items": {
            "type": "object",
            "required": ["file", "action", "language", "description"],
            "properties": {
              "file": {
                "type": "string",
                "description": "Path to the file to modify"
              },
              "action": {
                "type": "string",
                "description": "The action type, such as add_env_variable, read_env_variable, etc."
              },
              "language": {
                "type": "string",
                "description": "Programming or config language (e.g., python, dockerfile, yaml)"
              },
              "description": {
                "type": "string",
                "description": "Natural language description of the intent"
              },
              "variable": {
                "type": "string"
              },
              "source": {
                "type": "string",
                "enum": ["build_arg", "env", "static"]
              },
              "default": {
                "type": ["string", "null"]
              },
              "assign_to": {
                "type": "string"
              },
              "fallback": {
                "type": "string"
              },
              "function_name": {
                "type": "string"
              },
              "signature": {
                "type": "string"
              },
              "body": {
                "type": "array",
                "items": { "type": "string" }
              },
              "insert_after": {
                "type": "string"
              },
              "key": {
                "type": "string"
              },
              "old_value": {},
              "new_value": {},
              "package": {
                "type": "string"
              },
              "version": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "code_files": {
          "type": "array",
          "description": "Ordered list of file-level deterministic planning instructions. A single file may appear multiple times if edits must occur in interleaved stages due to dependencies.",
          "items": {
            "type": "object",
            "required": [
              "code_file_path",
              "instructions",
              "guidance",
              "code_writing_model"
            ],
            "properties": {
              "code_file_path": {
                "type": "string",
                "description": "Relative file path to be created or modified"
              },
              "guidance": {
                "type": "string",
                "description": "Strategic advice for the code writer based on trends or previous iteration summaries"
              },
              "instructions": {
                "type": "array",
                "description": "Ordered steps for how the code_writer should modify the file",
                "items": {
                  "type": "object",
                  "required": ["step_number", "action", "details"],
                  "properties": {
                    "step_number": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Step number in execution order"
                    },
                    "action": {
                      "type": "string",
                      "description": "Short summary of the operation, e.g., 'create function `train`'"
                    },
                    "details": {
                      "type": "string",
                      "description": "Detailed, testable description of the change"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "dsl_instructions": {
                "type": "array",
                "description": "Structured instructions using Erie Iron DSL format for this specific file",
                "items": {
                  "type": "object",
                  "required": ["action", "language", "description"],
                  "properties": {
                    "action": {
                      "type": "string",
                      "description": "DSL action type (e.g., add_env_variable, read_env_variable, etc.)"
                    },
                    "language": {
                      "type": "string",
                      "description": "Programming or config language"
                    },
                    "description": {
                      "type": "string",
                      "description": "Explanation of the change"
                    },
                    "variable": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string",
                      "enum": ["build_arg", "env", "static"]
                    },
                    "default": {
                      "type": ["string", "null"]
                    },
                    "assign_to": {
                      "type": "string"
                    },
                    "fallback": {
                      "type": "string"
                    },
                    "function_name": {
                      "type": "string"
                    },
                    "signature": {
                      "type": "string"
                    },
                    "body": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "insert_after": {
                      "type": "string"
                    },
                    "key": {
                      "type": "string"
                    },
                    "old_value": {},
                    "new_value": {},
                    "package": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "code_writing_model": {
                "type": "string",
                "description": "LLM model name to be used for generating this file",
                "enum": [
                  "claude-3-opus-20240229",
                  "gpt-4o-2024-08-06",
                  "gpt-4o",
                  "gpt-4-turbo",
                  "claude-3-7-sonnet-20250219",
                  "claude-3-5-sonnet-20240620",
                  "o3-pro-2025-06-10",
                  "o3-mini-2025-01-31"
                ]
              },
              "related_code_file_paths": {
                "type": "array",
                "description": "Other files being modified in this iteration that may be useful for context. Read-only. Do not edit these files.  Files must be expressed as relative to the code-root directory.  Must not start with a '/'",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Blocked Task",
      "required": ["blocked"],
      "properties": {
        "blocked": {
          "type": "object",
          "required": ["category", "reason"],
          "properties": {
            "category": {
              "type": "string",
              "enum": ["task_def", "infra", "missing_context", "permissions", "unexpected_error"],
              "description": "Reason category for blocking"
            },
            "reason": {
              "type": "string",
              "description": "Explanation of why planning is blocked"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}