{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DesignLeadOutput",
  "type": "object",
  "required": [
    "initiative_id",
    "design_handoff"
  ],
  "properties": {
    "initiative_id": {
      "type": "string"
    },
    "design_handoff": {
      "type": "object",
      "required": ["component_ids", "layout", "style_tokens"],
      "properties": {
        "component_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "layout": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "type": "string" },
            "regions": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "components": {
              "type": "array",
              "items": { "type": "string" }
            },
            "responsive": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "style_tokens": {
          "type": "object",
          "properties": {
            "primary_color": { "type": "string" },
            "background_color": { "type": "string" },
            "text_color": { "type": "string" },
            "button_color": { "type": "string" },
            "card_background": { "type": "string" },
            "accent_color": { "type": "string" },
            "font_family": { "type": "string" },
            "font_size_heading": { "type": "string" },
            "font_size_body": { "type": "string" },
            "padding_md": { "type": "string" },
            "gap_sm": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}