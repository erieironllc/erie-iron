{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FailureModeRouterOutput",
  "type": "object",
  "required": ["classification", "recovery_path", "recovery_path_explanation"],
  "properties": {
    "classification": {
      "type": "string",
      "enum": [
        "SYNTAX_ERROR",
        "IMPORT_ERROR",
        "VERSION_MISMATCH",
        "ATTRIBUTE_ERROR",
        "MISSING_DEPENDENCY",
        "CONFIGURATION_ERROR",
        "NETWORK_ERROR",
        "UNKNOWN"
      ]
    },
    "recovery_path": {
      "type": "string",
      "enum": [
        "DIRECT_FIX",
        "ESCALATE_TO_PLANNER",
        "AWS_PROVISIONING_PLANNER",
        "ESCALATE_TO_HUMAN"
      ]
    },
    "recovery_path_explanation": {
      "type": "string",
      "description": "Your reasoning for why you chose the recovery path"
    },
    "fix_prompt": {
      "type": "string",
      "description": "Concise (1–2 sentence) question or request for clarification when the error is ambiguous or 'mysterious'. Leave blank if the error is well defined and self-explanatory."
    },
    "context_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Relative paths of code files needed by the quick fix agent"
    }
  },
  "additionalProperties": false
}