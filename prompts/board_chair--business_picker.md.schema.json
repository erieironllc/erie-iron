{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Erie Iron Board Chair Business Picker Output",
  "type": "object",
  "required": [
    "research_methodology",
    "eliminated_businesses",
    "top_ranked_businesses",
    "ranking_rationale",
    "strategic_considerations"
  ],
  "properties": {
    "research_methodology": {
      "type": "object",
      "required": [
        "businesses_analyzed",
        "competitors_researched_per_business",
        "searches_conducted",
        "research_confidence",
        "key_research_findings"
      ],
      "properties": {
        "businesses_analyzed": { "type": "integer", "minimum": 0 },
        "competitors_researched_per_business": { "type": "string" },
        "searches_conducted": { "type": "integer", "minimum": 0 },
        "research_confidence": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW"]
        },
        "key_research_findings": { "type": "string" }
      }
    },

    "eliminated_businesses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "business_name",
          "elimination_reason",
          "research_findings"
        ],
        "properties": {
          "business_name": { "type": "string" },
          "elimination_reason": { "type": "string" },
          "research_findings": { "type": "string" }
        }
      }
    },

    "top_ranked_businesses": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "rank",
          "business_id",
          "business_name",
          "confidence_score",
          "research_validated_positioning",
          "justification",
          "risk_assessment",
          "research_support"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "enum": [1, 2, 3]
          },
          "business_id": { "type": "string" },
          "business_name": { "type": "string" },
          "confidence_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          },

          "research_validated_positioning": {
            "type": "object",
            "required": [
              "claimed_differentiation",
              "actual_differentiation",
              "competitors_found",
              "competitive_reality",
              "wedge_strength",
              "wedge_defensibility_months",
              "revised_go_no_go"
            ],
            "properties": {
              "claimed_differentiation": { "type": "string" },
              "actual_differentiation": { "type": "string" },
              "competitors_found": {
                "type": "array",
                "items": { "type": "string" }
              },
              "competitive_reality": {
                "type": "string",
                "enum": ["WHITE_SPACE", "GAPS_EXIST", "COMPETITIVE", "SATURATED"]
              },
              "wedge_strength": {
                "type": "string",
                "enum": ["STRONG", "WEAK", "NONEXISTENT"]
              },
              "wedge_defensibility_months": { "type": "integer", "minimum": 0 },
              "revised_go_no_go": {
                "type": "string",
                "enum": ["GO", "REVISE_NICHE", "NO_GO"]
              }
            }
          },

          "justification": {
            "type": "object",
            "required": [
              "why_this_rank",
              "competitive_advantage",
              "financial_potential",
              "resource_alignment",
              "risk_factors"
            ],
            "properties": {
              "why_this_rank": { "type": "string" },
              "competitive_advantage": { "type": "string" },
              "financial_potential": { "type": "string" },
              "resource_alignment": { "type": "string" },
              "risk_factors": { "type": "string" }
            }
          },

          "risk_assessment": {
            "type": "object",
            "required": [
              "overall_risk_level",
              "primary_risks",
              "mitigation_strategies",
              "cash_flow_timeline"
            ],
            "properties": {
              "overall_risk_level": {
                "type": "string",
                "enum": ["LOW", "MEDIUM", "HIGH"]
              },
              "primary_risks": {
                "type": "array",
                "items": { "type": "string" }
              },
              "mitigation_strategies": {
                "type": "array",
                "items": { "type": "string" }
              },
              "cash_flow_timeline": { "type": "string" }
            }
          },

          "research_support": {
            "type": "object",
            "required": [
              "key_searches_conducted",
              "validation_points",
              "concerns_identified"
            ],
            "properties": {
              "key_searches_conducted": {
                "type": "array",
                "items": { "type": "string" }
              },
              "validation_points": {
                "type": "array",
                "items": { "type": "string" }
              },
              "concerns_identified": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "ranking_rationale": {
      "type": "object",
      "required": [
        "methodology_used",
        "primary_differentiators",
        "research_impact",
        "confidence_in_rankings"
      ],
      "properties": {
        "methodology_used": { "type": "string" },
        "primary_differentiators": { "type": "string" },
        "research_impact": { "type": "string" },
        "confidence_in_rankings": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW"]
        }
      }
    },

    "strategic_considerations": {
      "type": "object",
      "required": [
        "portfolio_balance",
        "execution_sequence",
        "resource_requirements",
        "risk_diversification"
      ],
      "properties": {
        "portfolio_balance": { "type": "string" },
        "execution_sequence": { "type": "string" },
        "resource_requirements": { "type": "string" },
        "risk_diversification": { "type": "string" }
      }
    }
  }
}