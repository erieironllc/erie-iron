{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EngineeringTaskOutput",
  "type": "object",
  "required": [
    "business_name",
    "initiative_id",
    "tasks"
  ],
  "properties": {
    "business_name": {
      "type": "string"
    },
    "initiative_id": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "depends_on",
          "task_description",
          "input_fields",
          "output_fields",
          "risk_notes",
          "requires_test",
          "completion_criteria",
          "execution_schedule",
          "timeout_seconds",
          "validated_requirements",
          "task_type"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^task_[a-z0-9_]+$",
            "description": "Unique lowercase snake_case ID matching ^task_[a-z0-9_]+$"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of task_ids that must complete first"
          },
          "task_description": {
            "type": "string",
            "description": "Clear description of the work"
          },
          "input_fields": {
            "type": "object",
            "patternProperties": {
              "^task_[a-z0-9_]+$": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false,
            "description": "Dict mapping upstream task_ids to arrays of field names from their outputs"
          },
          "output_fields": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of output field names this task produces"
          },
          "risk_notes": {
            "type": "string",
            "description": "Operational or automation risk notes"
          },
          "requires_test": {
            "type": "boolean",
            "description": "Whether an automated test is required"
          },
          "completion_criteria": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Acceptance criteria for successful completion"
          },
          "execution_schedule": {
            "type": "string",
            "enum": ["NOT_APPLICABLE", "ONCE", "HOURLY", "DAILY", "WEEKLY", "DAEMON"],
            "description": "Schedule: NOT_APPLICABLE, ONCE, HOURLY, DAILY, WEEKLY, or DAEMON"
          },
          "execution_start_time": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 UTC datetime ending with Z for first run"
          },
          "timeout_seconds": {
            "type": "integer",
            "description": "Max run time in seconds (e.g. 3×p99 or ≤7200 for non-DAEMON)"
          },
          "validated_requirements": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of requirement IDs this task validates (can be empty)"
          },
          "task_type": {
            "type": "string",
            "enum": ["CODING_APPLICATION", "TASK_EXECUTION", "CODING_ML", "DESIGN_WEB_APPLICATION", "HUMAN_WORK"],
            "description": "High-level nature of the task"
          },
          "implementation_phase": {
            "type": ["string", "null"],
            "enum": ["UI_MOCK_API", "SERVER_IMPLEMENTATION", null],
            "description": "For React/React Native projects: UI_MOCK_API for Phase 1 tasks (no AWS), SERVER_IMPLEMENTATION for Phase 2 tasks (with AWS). Null for non-UI tasks."
          }
        }
      }
    }
  }
}
