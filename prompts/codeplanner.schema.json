{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/codeplanner-base-output.schema.json",
  "title": "CodePlannerBaseOutput",
  "description": "Structured output of the Erie Iron code planner agent",
  "type": "object",
  "oneOf": [
    {
      "title": "Planned Code Change",
      "required": ["code_files"],
      "properties": {
        "required_credentials": {
          "type": "object",
          "description": "Optional. Mapping of service names to credential specification objects required for this code change. Each key is a service name (e.g., 'github', 'openai', 'aws'), and each value describes the expected secret in AWS Secrets Manager.",
          "additionalProperties": {
            "type": "object",
            "description": "Describes the secret required for a service, including how to find it and its schema.",
            "required": ["secret_arn_env_var", "schema"],
            "properties": {
              "secret_arn_env_var": {
                "type": "string",
                "description": "Name of the environment variable that will contain the AWS Secrets Manager secret ARN at runtime."
              },
              "secret_arn_cfn_parameter": {
                "type": "string",
                "description": "Name of the CloudFormation parameter that should receive this secret's ARN during stack deployment. If present, the plan must include infrastructure.yaml edits to add this parameter, wire it into resources using dynamic references, and attach the secret if applicable."
              },
              "schema": {
                "type": "array",
                "description": "Array describing each key/value pair expected inside the secret object.",
                "items": {
                  "type": "object",
                  "required": ["key", "type", "required", "description"],
                  "properties": {
                    "key": {
                      "type": "string",
                      "description": "Key name as stored inside the secret."
                    },
                    "type": {
                      "type": "string",
                      "description": "Type of the value (valid values are JSON Schema types such as 'string', 'number', 'boolean', 'object', etc.)."
                    },
                    "required": {
                      "type": "boolean",
                      "description": "Whether this key is required in the secret."
                    },
                    "description": {
                      "type": "string",
                      "description": "Description of the key and its purpose for this service."
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "lessons_applied": {
          "type": "array",
          "description": "List of past lesson patterns that influenced this plan",
          "items": {
            "type": "string"
          }
        },
        "dsl_plan": {
          "type": "array",
          "description": "Structured plan using DSL format for multi-file coordination",
          "items": {
            "type": "object",
            "required": ["file", "action", "language", "description"],
            "properties": {
              "file": {
                "type": "string",
                "description": "Path to the file to modify"
              },
              "action": {
                "type": "string",
                "description": "The action type, such as add_env_variable, read_env_variable, etc."
              },
              "language": {
                "type": "string",
                "description": "Programming or config language (e.g., python, dockerfile, yaml)"
              },
              "description": {
                "type": "string",
                "description": "Natural language description of the intent"
              },
              "variable": {
                "type": "string"
              },
              "source": {
                "type": "string",
                "enum": ["build_arg", "env", "static"]
              },
              "default": {
                "type": ["string", "null"]
              },
              "assign_to": {
                "type": "string"
              },
              "fallback": {
                "type": "string"
              },
              "function_name": {
                "type": "string"
              },
              "signature": {
                "type": "string"
              },
              "body": {
                "type": "array",
                "items": { "type": "string" }
              },
              "insert_after": {
                "type": "string"
              },
              "key": {
                "type": "string"
              },
              "old_value": {},
              "new_value": {},
              "package": {
                "type": "string"
              },
              "version": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "code_files": {
          "type": "array",
          "description": "Ordered list of file-level deterministic planning instructions. A single file may appear multiple times if edits must occur in interleaved stages due to dependencies.",
          "items": {
            "type": "object",
            "required": [
              "code_file_path",
              "instructions",
              "guidance",
              "code_writing_model"
            ],
            "properties": {
              "code_file_path": {
                "type": "string",
                "description": "Relative file path to be created or modified"
              },
              "guidance": {
                "type": "string",
                "minLength": 1,
                "description": "Strategic advice for the code writer; this field is mandatory and must be written for the code writer (not meta-commentary)."
              },
              "validator": {
                "type": "string",
                "description": "Strategic advice for the code writer based on trends or previous iteration summaries"
              },
              "instructions": {
                "type": "array",
                "description": "Ordered steps for how the code_writer should modify the file",
                "items": {
                  "type": "object",
                  "required": ["step_number", "action", "details"],
                  "properties": {
                    "step_number": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Step number in execution order"
                    },
                    "action": {
                      "type": "string",
                      "description": "Short summary of the operation, e.g., 'create function `train`'"
                    },
                    "details": {
                      "type": "string",
                      "description": "Detailed, testable description of the change"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "dsl_instructions": {
                "type": "array",
                "description": "Structured instructions using Erie Iron DSL format for this specific file",
                "items": {
                  "type": "object",
                  "required": ["action", "language", "description"],
                  "properties": {
                    "action": {
                      "type": "string",
                      "description": "DSL action type (e.g., add_env_variable, read_env_variable, etc.)"
                    },
                    "language": {
                      "type": "string",
                      "description": "Programming or config language"
                    },
                    "description": {
                      "type": "string",
                      "description": "Explanation of the change"
                    },
                    "variable": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string",
                      "enum": ["build_arg", "env", "static"]
                    },
                    "default": {
                      "type": ["string", "null"]
                    },
                    "assign_to": {
                      "type": "string"
                    },
                    "fallback": {
                      "type": "string"
                    },
                    "function_name": {
                      "type": "string"
                    },
                    "signature": {
                      "type": "string"
                    },
                    "body": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "insert_after": {
                      "type": "string"
                    },
                    "key": {
                      "type": "string"
                    },
                    "old_value": {},
                    "new_value": {},
                    "package": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "code_writing_model": {
                "type": "string",
                "description": "LLM model name to be used for generating this file",
                "enum": [
                  "gpt-5",
                  "gpt-5-mini",
                  "gpt-5-nano"
                ]
              },
              "related_code_file_paths": {
                "type": "array",
                "description": "Other files being modified in this iteration that may be useful for context. Read-only. Do not edit these files.  Files must be expressed as relative to the code-root directory.  Must not start with a '/'",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Blocked Task",
      "required": ["blocked"],
      "properties": {
        "blocked": {
          "type": "object",
          "required": ["category", "reason"],
          "properties": {
            "category": {
              "type": "string",
              "enum": ["task_def", "infra", "missing_context", "permissions", "unexpected_error"],
              "description": "Reason category for blocking"
            },
            "reason": {
              "type": "string",
              "description": "Explanation of why planning is blocked"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}