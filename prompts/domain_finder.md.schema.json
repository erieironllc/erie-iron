{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DomainFinderOutput",
  "type": "object",
  "properties": {
    "suggested_domains": {
      "type": "array",
      "description": "List of 10 domain names in order of preference",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9.-]+\\.[a-zA-Z]{2,}$"
      },
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true
    }
  },
  "required": ["suggested_domains"],
  "additionalProperties": false
}